# ──────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bahamut_oms
DB_HOST=postgres
DB_PORT=5432
# Alternative: set a full connection string to override individual vars
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bahamut_oms
# Supabase: use your Supabase Postgres URL as DATABASE_URL and enable SSL
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# DB_SSL=true

# ──────────────────────────────────────────────────
# Node / Server
# ──────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=5000
FRONTEND_PORT=3000
PORT=5000

# ──────────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-at-least-32-chars
ENCRYPTION_KEY=32-char-hex-key-change-in-production

# ──────────────────────────────────────────────────
# CORS (comma-separated list of allowed origins)
# ──────────────────────────────────────────────────
# CORS_ORIGIN=https://app.bahamut.io,https://bahamut.io
# FRONTEND_URL=https://app.bahamut.io

# ──────────────────────────────────────────────────
# Stripe  (required for payments & subscriptions)
# ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────────────
# Google OAuth  (required for social login)
# ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID is set in frontend build; mirrors GOOGLE_CLIENT_ID

# ──────────────────────────────────────────────────
# Email / SMTP  (required for transactional email)
# ──────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
SENDGRID_SMTP_HOST=smtp.sendgrid.net
SENDGRID_SMTP_PORT=587
SENDGRID_SMTP_USER=apikey
EMAIL_FROM=no-reply@bahamut.io
EMAIL_FROM_NAME=Bahamut OMS
EMAIL_NOTIFICATIONS_ENABLED=true

# ──────────────────────────────────────────────────
# SMS / Twilio  (optional – for SMS notifications)
# ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ──────────────────────────────────────────────────
# Shipping Carriers
# ──────────────────────────────────────────────────
# DHL
DHL_API_KEY=your-dhl-api-key
DHL_API_URL=https://api.dhl.com
DHL_ACCOUNT_NUMBER=your-dhl-account

# FedEx
FEDEX_CLIENT_ID=your-fedex-client-id
FEDEX_CLIENT_SECRET=your-fedex-client-secret
FEDEX_API_URL=https://apis.fedex.com
FEDEX_ACCOUNT_NUMBER=your-fedex-account

# UPS
UPS_USERNAME=your-ups-username
UPS_PASSWORD=your-ups-password
UPS_ACCESS_KEY=your-ups-access-key
UPS_API_URL=https://onlinetools.ups.com

# ──────────────────────────────────────────────────
# Firebase  (optional – for push notifications)
# ──────────────────────────────────────────────────
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ──────────────────────────────────────────────────
# pgAdmin (docker-compose dev only)
# ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
