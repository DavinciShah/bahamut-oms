# Server
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://localhost:5432/bahamut_oms
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_NAME=bahamut_oms

# JWT Settings
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
JWT_EXPIRATION=3600

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# CORS
CORS_ORIGIN=http://localhost:3000

# Tally
TALLY_HOST=localhost
TALLY_PORT=9000

# Zoho Books
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=http://localhost:5000/api/integrations/zoho/callback

# QuickBooks
QB_CLIENT_ID=your-quickbooks-client-id
QB_CLIENT_SECRET=your-quickbooks-client-secret
QB_REDIRECT_URI=http://localhost:5000/api/integrations/quickbooks/callback
QB_ENVIRONMENT=sandbox

# MyBillBook
MYBILLBOOK_API_BASE_URL=https://api.mybillbook.com/v1

# Accounting Software Integration (generic)
ACCOUNTING_API_KEY=your-accounting-api-key
ACCOUNTING_API_SECRET=your-accounting-api-secret
