NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bahamut_oms
DB_USER=postgres
DB_PASSWORD=password

# Optional: use DATABASE_URL to override individual DB settings
# DATABASE_URL=postgresql://user:password@host:5432/bahamut_oms
# Supabase (recommended): set DATABASE_URL to your Supabase Postgres connection string
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# DB_SSL=true

# Server Configuration (production overrides)
# NODE_ENV=production
# DB_HOST=postgres
# DB_USER=bahamut_user
# DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# JWT Settings
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# API Settings
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3000
# Comma-separated list of trusted frontend origins in production:
# CORS_ORIGIN=https://app.yourdomain.com,https://admin.yourdomain.com
#
# Set to true ONLY if native/desktop apps (Capacitor, Electron) must reach this
# API in production without sending an Origin header (null-origin bypass risk):
# CORS_ALLOW_NULL_ORIGIN=false

# Google SSO Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Accounting Software Integration (optional)
ACCOUNTING_API_KEY=your-accounting-api-key
ACCOUNTING_API_SECRET=your-accounting-api-secret

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Stripe Configuration (optional)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Webhook Secrets
# Shared secret for verifying inbound shipping carrier webhooks (FedEx, UPS, DHL).
# Generate with: openssl rand -hex 32
SHIPPING_WEBHOOK_SECRET=change_me_generate_with_openssl_rand_hex_32
# Shared secret for verifying inbound accounting-system webhook events.
ACCOUNTING_WEBHOOK_SECRET=change_me_generate_with_openssl_rand_hex_32

# Logging
LOG_LEVEL=info
