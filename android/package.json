{
  "name": "bahamut-oms-android",
  "version": "1.0.0",
  "private": true,
  "description": "Android shell for Bahamut OMS",
  "scripts": {
    "build:web": "npm --prefix ../frontend run build && node ./scripts/write-runtime-config.mjs",
    "sync": "npm run build:web && npx cap sync android",
    "doctor": "npx cap doctor",
    "open": "npx cap open android"
  },
  "keywords": [
    "capacitor",
    "android",
    "webview"
  ],
  "license": "MIT",
  "devDependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^7.6.5"
  }
}
